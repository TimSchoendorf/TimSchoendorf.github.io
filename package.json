    "build:pokemon-draft:data": "node scripts/generate-pokemon-draft-data.mjs",
    "build:pokemon-draft:bundle": "esbuild src/pokemon-draft-app.js --bundle --platform=browser --format=iife --minify --outfile=games/pokemon-draft.js",
